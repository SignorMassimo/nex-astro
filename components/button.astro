---
interface Props {
    label: string;
}

const { label } = Astro.props;
---

<button class="nex-btn">
    {label}
</button>

<style>
    .nex-btn {
        background-color: #007bff;
        color: white;
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
    }
</style>
